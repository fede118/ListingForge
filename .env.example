# Copy to .env and fill in. Load before running:  set -a; source .env; set +a
ETSY_KEYSTRING=your_keystring_here
ETSY_SHARED_SECRET=your_shared_secret_here
ETSY_REDIRECT_URI=http://localhost:8080/auth/callback
OAUTH_SCOPES=shops_r
# Any long random string; signs the session cookie so it can't be forged.
SESSION_SIGN_KEY=change_me_to_a_long_random_string
# Origin of the web client. Used for CORS AND as the post-login redirect target
# (the BFF sends the browser back here after the OAuth callback succeeds).
FRONTEND_ORIGIN=http://localhost:3000
# Keep false on http localhost; set true once you're behind HTTPS.
COOKIE_SECURE=false
# Deep link the BFF redirects the Android app to after login (the session token
# rides on the URL fragment). The app must register this scheme.
ANDROID_AUTH_DEEPLINK=listingforge://auth
# Lifetime of an Android bearer session token, in seconds. Default 30 days.
SESSION_TOKEN_TTL_SECONDS=2592000
SERVER_PORT=8080
DB_PATH=listingforge.db
# Etsy endpoints. Defaults are the real production URLs; override only to point
# at a stub/sandbox host (e.g. in tests). Leave unset for normal use.
# ETSY_AUTHORIZE_URL=https://www.etsy.com/oauth/connect
# ETSY_TOKEN_URL=https://api.etsy.com/v3/public/oauth/token
# ETSY_API_BASE=https://api.etsy.com/v3/application
